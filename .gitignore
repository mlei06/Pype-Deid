.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/
.env
.env.local
# Legacy DB location — the default moved to data/app.sqlite. These rules catch
# any stray files left behind by old checkouts or custom CLINICAL_DEID_DATABASE_URL.
var/*.sqlite
var/*.sqlite-journal
# Data workspace — keep layout, ignore user files.
# All mutable runtime state lives under data/ (see data/README.md).
data/app.sqlite
data/app.sqlite-journal
data/app.sqlite-shm
data/app.sqlite-wal
data/raw/*
!data/raw/.gitkeep
data/corpora/*
!data/corpora/.gitkeep
# Ship small tracked corpora for demo/docs (see data/README.md):
#   sample_notes              — 15 annotated production-export notes
#   sample_notes_surrogated   — same notes with synthesized PHI surrogates
!data/corpora/sample_notes/
!data/corpora/sample_notes/**
!data/corpora/sample_notes_surrogated/
!data/corpora/sample_notes_surrogated/**
data/evaluations/*
!data/evaluations/.gitkeep
data/inference_runs/*
!data/inference_runs/.gitkeep
data/batch/
data/exports/
# Pipelines and modes.json ship as tracked seed files; ignore anything else
# operators create at runtime so the working tree stays clean.
data/pipelines/*
!data/pipelines/*.json
!data/pipelines/.gitkeep
# Model directory — keep layout, ignore model files
models/spacy/*
!models/spacy/.gitkeep
models/huggingface/*
!models/huggingface/.gitkeep
models/external/*
!models/external/.gitkeep
.DS_Store
.idea/
.vscode/
.claude/
frontend/.claude/
# NeuroNER — venv, runtime scratch, and large data files
neuroner-cspmc/venv/
neuroner-cspmc/data/temp/
data/word_vectors/
data/neuroner_deploy/
models/neuroner/
output/neuroner/
# Sibling project checked out into the working tree (never part of this repo)
vsee-intelligent-hub/

{
  "pipes": [
    {
      "type": "regex_ner",
      "config": {
        "source_name": "regex_ner",
        "pattern_pack": "clinical_phi",
        "skip_overlapping": false,
        "labels": {
          "ADDRESS": {
            "enabled": true,
            "remap": "LOCATION",
            "custom_pattern": null
          },
          "DATE_TIME": {
            "enabled": true,
            "remap": "DATE",
            "custom_pattern": null
          },
          "IP_ADDRESS": {
            "enabled": false,
            "remap": null,
            "custom_pattern": null
          },
          "SSN": {
            "enabled": true,
            "remap": "ID",
            "custom_pattern": null
          },
          "URL": {
            "enabled": false,
            "remap": null,
            "custom_pattern": null
          }
        }
      }
    },
    {
      "type": "whitelist",
      "config": {
        "source_name": "whitelist",
        "skip_overlapping": false,
        "labels": {
          "NAME": {
            "enabled": true,
            "remap": null,
            "terms": [
              "Sarah"
            ],
            "disabled_dictionaries": [
              "local_places_unambig_v2",
              "us_cities",
              "us_hospitals",
              "us_states"
            ]
          },
          "LOCATION": {
            "enabled": true,
            "remap": null,
            "terms": [],
            "disabled_dictionaries": [
              "female_first_names",
              "last_names",
              "male-first-names"
            ]
          }
        }
      }
    },
    {
      "type": "blacklist",
      "config": {
        "dict_config": {
          "disabled_dictionaries": [
            "common_words",
            "sno_edited",
            "commonest_words"
          ]
        },
        "match": "any_token",
        "apply_to_labels": null,
        "load_all_dictionaries": true
      }
    },
    {
      "type": "huggingface_ner",
      "config": {
        "model": "mimic-clinicalbert-sentence",
        "segmentation": "auto",
        "source_name": "huggingface_ner",
        "skip_overlapping": false
      }
    },
    {
      "type": "label_mapper",
      "config": {
        "mapping": {
          "PERSON": "NAME",
          "PER": "NAME",
          "PATIENT": "NAME",
          "DOCTOR": "NAME",
          "STAFF": "NAME",
          "HCW": "NAME",
          "DATE_TIME": "DATE",
          "TIME": "DATE",
          "PHONE_NUMBER": "PHONE",
          "EMAIL_ADDRESS": "EMAIL",
          "IP_ADDRESS": "ID",
          "US_SSN": "ID",
          "SSN": "ID",
          "MRN": "ID",
          "MEDICAL_LICENSE": "ID",
          "US_DRIVER_LICENSE": "ID",
          "US_PASSPORT": "ID",
          "US_BANK_NUMBER": "ID",
          "CREDIT_CARD": "ID",
          "IBAN_CODE": "ID",
          "US_ITIN": "ID",
          "US_NPI": "ID",
          "US_DEA": "ID",
          "US_MBI": "ID",
          "UK_NHS": "ID",
          "FACILITY": "ORGANIZATION",
          "FAC": "ORGANIZATION",
          "HOSP": "ORGANIZATION",
          "HOSPITAL": "ORGANIZATION",
          "PATORG": "ORGANIZATION",
          "ORG": "ORGANIZATION",
          "GPE": "LOCATION",
          "LOC": "LOCATION",
          "ADDRESS": "LOCATION",
          "URL": null,
          "CRYPTO": null,
          "NRP": null,
          "NORP": null,
          "PROFESSION": null,
          "CONTACT": null,
          "OTHERPHI": null
        },
        "drop_unmapped": false
      }
    }
  ],
  "description": "Clinical Transformer — regex + whitelist + blacklist + HuggingFace NER (mimic-clinicalbert-sentence). Canonical 8-label output via label_mapper.",
  "output_label_space": [
    "AGE",
    "DATE",
    "EMAIL",
    "ID",
    "LOCATION",
    "NAME",
    "ORGANIZATION",
    "PHONE"
  ]
}

# PypeDeid — backend environment template
#
# Copy to ".env" in the repo root (gitignored) or set PYPEDEID_ENV_FILE to an absolute path.
# Docker Compose: root ``compose.yaml`` loads this file into the API container when present
# (``env_file``, optional). Use it for production keys without editing the Compose file.
# Resolution order: PYPEDEID_ENV_FILE → walk up from cwd for ".env" → ".env" next to pyproject.toml.
#
# Pydantic Settings: env_prefix PYPEDEID_ for most fields. List-valued settings expect JSON arrays.
# API entry point: pypedeid-api (single FastAPI app; see docs/deployment.md).

# =============================================================================
# Optional API authentication
# =============================================================================
# JSON arrays of secret strings. When BOTH lists are empty/unset, auth is OFF (local dev; /docs enabled).
# When either list is non-empty, clients must send Authorization: Bearer <key> or X-API-Key: <key>.
# Admin keys satisfy all routes; inference keys are limited (see docs/api.md and tests/test_auth_contract.py).
# OpenAPI /docs /redoc /openapi.json are disabled for anonymous users when auth is enabled.
#
# PYPEDEID_ADMIN_API_KEYS=["change-me-admin"]
# PYPEDEID_INFERENCE_API_KEYS=["change-me-inference"]

# =============================================================================
# CORS (browser SPAs: Playground :3000, production UI :3001, or remote origins)
# =============================================================================
# Default if unset: ["http://localhost:3000","http://127.0.0.1:3000"]
# PYPEDEID_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3001"]

# =============================================================================
# Request body size cap (bytes). Requests above this are rejected with 413 at the edge.
# =============================================================================
# Default: 10 MiB (10485760). Applies before handlers run (e.g. POST /dictionaries, POST /datasets/upload).
# Raise for large JSONL browser uploads or Production “Register on server” exports.
# PYPEDEID_MAX_BODY_BYTES=10485760

# =============================================================================
# Paths & storage (all optional; paths are relative to the process working directory unless absolute)
# =============================================================================
# All mutable state defaults to ./data/ so a deployment mounts one volume.
# Models are read-only at runtime and default to ./models/.
# PYPEDEID_DATABASE_URL=sqlite:///./data/app.sqlite
# PYPEDEID_PIPELINES_DIR=data/pipelines
# PYPEDEID_MODES_PATH=data/modes.json
# PYPEDEID_EVALUATIONS_DIR=data/evaluations
# PYPEDEID_INFERENCE_RUNS_DIR=data/inference_runs
# PYPEDEID_MODELS_DIR=models
# PYPEDEID_DICTIONARIES_DIR=data/dictionaries
# Corpus root: each dataset is ``<CORPORA_DIR>/<name>/corpus.jsonl`` + ``dataset.json`` (JSONL only).
# POST /datasets/upload writes via import_jsonl_dataset into this tree (admin key when auth is on).
# PYPEDEID_CORPORA_DIR=data/corpora
# Exports (BRAT, CoNLL, etc.) from ``POST /datasets/{name}/export`` default here — outside corpora.
# PYPEDEID_EXPORTS_DIR=data/exports
# Deprecated alias for CORPORA_DIR (logs a warning):
# PYPEDEID_PROCESSED_DIR=

# =============================================================================
# Deploy / modes (file on disk, not an env var)
# =============================================================================
# Mode aliases and pipeline allowlist live in data/modes.json (override with
# PYPEDEID_MODES_PATH). Edited via GET/PUT /deploy and the Deploy tab; the
# file must be writable when operators save deploy changes.

# =============================================================================
# Label space + risk profile (pluggable NER / eval; see docs/configuration.md)
# =============================================================================
# Defaults: clinical_phi. Use generic_pii for a minimal non-clinical label set and
# uniform risk weights. Regex/surrogate pipes still use their own pattern_pack /
# strategy_pack unless you set those to match.
# PYPEDEID_LABEL_SPACE_NAME=clinical_phi
# PYPEDEID_RISK_PROFILE_NAME=clinical_phi

# =============================================================================
# OpenAI-compatible API (LLM synthesis, dataset generation, llm_ner when configured)
# =============================================================================
# API key: either name works (no PYPEDEID_ prefix on OPENAI_API_KEY).
OPENAI_API_KEY=sk-WWtLD3jVn0V7wMLtzi23Nw
# PYPEDEID_OPENAI_API_KEY=

# Base URL and model (optional; defaults in code match gpt-4o-mini @ api.openai.com).
# Aliases: PYPEDEID_OPENAI_BASE_URL, PYPEDEID_OPENAI_MODEL
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# NeuroNER HTTP sidecar (neuroner-cspmc/sidecar; neuroner_ner pipe default base URL)
# =============================================================================
# PYPEDEID_NEURONER_HTTP_URL=http://127.0.0.1:8765
# NEURONER_HTTP_URL=http://127.0.0.1:8765
